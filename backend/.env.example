# Example environment variables for local development
DB_USER=postgres
DB_PASSWORD=secret
# Production/CI can use Secret Manager instead of inline values:
# DB_PASSWORD_SECRET_NAME=vista-db-password
# DB_PASSWORD_SECRET_VERSION=latest
DB_NAME=vista_ai
DB_HOST=127.0.0.1
DB_PORT=5432

# Cloud SQL instance connection name (set only when using Cloud SQL via Unix sockets)
# CLOUDSQL_INSTANCE_CONNECTION_NAME=my-project:region:instance

# Firebase service account JSON file path
# FIREBASE_SERVICE_ACCOUNT_JSON=/secrets/firebase-adminsdk.json
# Or inject the raw JSON via Secret Manager in Cloud Run:
# FIREBASE_SERVICE_ACCOUNT_JSON_SECRET_NAME=vista-firebase-adminsdk
# FIREBASE_SERVICE_ACCOUNT_JSON_SECRET_VERSION=latest

# Optional Firebase Web config JSON for the browser client.
# If set, the UI auto-loads this and you do not need to paste it manually.
# VISTA_FIREBASE_WEB_CONFIG='{"apiKey":"...","authDomain":"...","projectId":"...","appId":"..."}'
# Or keep the same value in Secret Manager for Cloud Run / CI:
# VISTA_FIREBASE_WEB_CONFIG_SECRET_NAME=vista-firebase-web-config
# VISTA_FIREBASE_WEB_CONFIG_SECRET_VERSION=latest

# Model configuration
VISTA_MODEL_ID=gemini-live-2.5-flash-native-audio
VISTA_LOCATION=us-central1
VISTA_FALLBACK_LOCATION=us-central1
# VISTA_PROJECT_ID=my-gcp-project
VISTA_USE_ADK=false
# VISTA_MUSIC_SYSTEM_INSTRUCTIONS="Optional custom Eurydice prompt"
VISTA_SYSTEM_INSTRUCTIONS="""Paste your long constitution here"""
